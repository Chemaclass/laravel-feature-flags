{
    "name": "chemaclass/laravel-feature-flags",
    "description": "Agnostic feature flag management for Laravel with optional admin UI and per-scope overrides.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "feature-flags", "toggles", "scoped"],
    "homepage": "https://github.com/Chemaclass/laravel-feature-flags",
    "support": {
        "issues": "https://github.com/Chemaclass/laravel-feature-flags/issues",
        "source": "https://github.com/Chemaclass/laravel-feature-flags",
        "docs": "https://github.com/Chemaclass/laravel-feature-flags/tree/main/docs"
    },
    "authors": [
        {
            "name": "Jose M. Valera Reales",
            "email": "hi@chemaclass.es",
            "homepage": "https://chemaclass.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Chemaclass\\FeatureFlags\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chemaclass\\FeatureFlags\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chemaclass\\FeatureFlags\\FeatureFlagsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "pest",
        "test:unit": "pest --testsuite=Unit",
        "test:feature": "pest --testsuite=Feature",
        "stan": "phpstan analyse --memory-limit=512M",
        "fmt": "pint",
        "fmt:check": "pint --test",
        "serve": "@php vendor/bin/testbench serve --host=0.0.0.0",
        "build": [
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "post-autoload-dump": [
            "@php vendor/bin/testbench package:discover --ansi"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
