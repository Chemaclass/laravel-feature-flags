{
    "name": "chemaclass/laravel-feature-flags",
    "description": "Agnostic feature flag management for Laravel with optional admin UI and per-scope overrides.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "feature-flags", "toggles", "multi-tenant"],
    "authors": [
        {
            "name": "Chemaclass",
            "email": "chemaclass@outlook.es"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Chemaclass\\FeatureFlags\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chemaclass\\FeatureFlags\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chemaclass\\FeatureFlags\\FeatureFlagsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
